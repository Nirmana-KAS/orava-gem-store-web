# PostgreSQL connection string for Prisma pooled connections (Supabase pooler URL)
DATABASE_URL=

# Direct PostgreSQL connection string for Prisma migrations/introspection
DIRECT_URL=

# Auth.js secret used to sign/encrypt session tokens and cookies
NEXTAUTH_SECRET=

# Public base URL of deployed app (example: https://your-domain.com)
NEXTAUTH_URL=

# Google OAuth client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# Google OAuth client secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=

# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key
CLOUDINARY_API_KEY=

# Cloudinary API secret
CLOUDINARY_API_SECRET=

# Public Cloudinary cloud name for client-side widgets
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Public Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key for privileged server-side operations
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key for transactional email delivery
RESEND_API_KEY=

# Verified sender email address used by Resend
RESEND_FROM_EMAIL=info@oravagems.com

# Comma-separated admin email addresses used for admin notifications/access checks
ADMIN_EMAILS=

# Admin dashboard second-factor passkey
ADMIN_PASSKEY=

# Google Analytics measurement ID (optional)
NEXT_PUBLIC_GA_ID=
